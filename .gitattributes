# Forzar LF para shell scripts (CRÍTICO: CRLF rompe bash en Linux/Docker)
*.sh text eol=lf
entrypoint.sh text eol=lf

# Resto de archivos texto con LF
*.py text eol=lf
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.txt text eol=lf
*.cfg text eol=lf
*.ini text eol=lf
*.toml text eol=lf

# Archivos binarios — sin conversión
*.ico binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.pdf binary
*.pfx binary
*.p12 binary
